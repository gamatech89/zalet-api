APP_NAME=Zalet
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.yourdomain.com

# Frontend URL — used for CORS and payment callback redirects
FRONTEND_URL=https://yourdomain.com

APP_LOCALE=sr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ── Database (PostgreSQL required for production) ──
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=zalet
DB_USERNAME=zalet
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── WebSockets (Reverb) ──
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=zalet
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=api.yourdomain.com
REVERB_PORT=8080
REVERB_SCHEME=https

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Use Redis for cache/sessions in production for performance
CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail ──
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Raiffeisen Payment Gateway ──
RAIFFEISEN_MERCHANT_ID=
RAIFFEISEN_TERMINAL_ID=
RAIFFEISEN_GATEWAY_URL=https://ecommerce.raiffeisenbank.rs/rbrs/...
RAIFFEISEN_PORTAL_URL=https://merchantportal.raiffeisenbank.rs/...
RAIFFEISEN_WEBHOOK_SECRET=
RAIFFEISEN_SUCCESS_URL=${FRONTEND_URL}/payment/success
RAIFFEISEN_FAILURE_URL=${FRONTEND_URL}/payment/failure

# ── LiveKit (Live Streaming) ──
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_HOST=https://your-livekit-host.livekit.cloud
LIVEKIT_WS_URL=wss://your-livekit-host.livekit.cloud

# ── Google Places API ──
GOOGLE_PLACES_API_KEY=

VITE_APP_NAME="${APP_NAME}"
